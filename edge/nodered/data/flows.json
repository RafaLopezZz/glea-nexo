        "func": "const row = (msg.payload && msg.payload[0]) ? msg.payload[0] : {\n    total: 0, pending: 0, sending: 0, failed: 0, dead_letter: 0, sent: 0, last_ts: \"\", next_attempt_at: \"\"\n};\n\nconst text = `Outbox | total=${row.total} | pending=${row.pending} | sending=${row.sending} | failed=${row.failed} | dlq=${row.dead_letter} | sent=${row.sent} | next=${row.next_attempt_at || '-'} | last_ts=${row.last_ts}`;\n\nnode.status({ fill: (row.failed > 0 || row.dead_letter > 0) ? \"red\" : row.pending > 0 ? \"yellow\" : \"green\", shape: \"dot\", text });\n\nmsg.payload = row;\nmsg.summary = text;\nreturn msg;\n",
