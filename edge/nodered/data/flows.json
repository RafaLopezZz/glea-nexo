        "type": "function",
        "z": "tab_bridge",
        "name": "Select due outbox rows",
        "func": "msg.topic = `SELECT id, message_id, topic, payload, tries\nFROM outbox\nWHERE state IN ('PENDING', 'FAILED')\n  AND tries < 5\n  AND datetime(next_attempt_at) <= datetime('now')\nORDER BY next_attempt_at ASC, id ASC\nLIMIT 20;`;\nreturn msg;\n",
