    {
        "id": "replay_prepare_failure",
        "type": "function",
        "z": "tab_bridge",
        "name": "Prepare FAILED or DLQ",
        "func": "const replay = msg.replay || { id: null, tries: 0 };\nconst tries = Number(replay.tries || 0) + 1;\nconst delaySeconds = tries === 1 ? 30 : tries === 2 ? 60 : tries === 3 ? 120 : 300;\nconst nextAttemptAt = new Date(Date.now() + (delaySeconds * 1000)).toISOString();\nlet reason = 'Unknown replay error';\nif (msg.replayError) {\n  reason = msg.replayError;\n} else if (msg.error && msg.error.message) {\n  reason = String(msg.error.message);\n} else if (msg.statusCode) {\n  reason = `HTTP ${msg.statusCode}`;\n} else if (msg.payload != null) {\n  reason = typeof msg.payload === 'string' ? msg.payload : JSON.stringify(msg.payload);\n}\nmsg.params = {\n  $id: replay.id,\n  $last_error: String(reason).slice(0, 500),\n  $next_attempt_at: nextAttemptAt\n};\nif (tries >= 5 || msg.replayError) {\n  return [null, msg];\n}\nreturn [msg, null];\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
