        "topic": "SELECT   COUNT(*) AS total,   COALESCE(SUM(CASE WHEN state = 'PENDING' THEN 1 ELSE 0 END), 0) AS pending,   COALESCE(SUM(CASE WHEN state = 'SENDING' THEN 1 ELSE 0 END), 0) AS sending,   COALESCE(SUM(CASE WHEN state = 'FAILED' THEN 1 ELSE 0 END), 0) AS failed,   COALESCE(SUM(CASE WHEN state = 'DEAD_LETTER' THEN 1 ELSE 0 END), 0) AS dead_letter,   COALESCE(SUM(CASE WHEN state = 'SENT' THEN 1 ELSE 0 END), 0) AS sent,   COALESCE(MAX(ts), '') AS last_ts,   COALESCE(MIN(CASE WHEN state IN ('PENDING', 'FAILED') THEN next_attempt_at END), '') AS next_attempt_at FROM outbox;",
