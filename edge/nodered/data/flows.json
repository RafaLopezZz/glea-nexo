        "id": "replay_load_message",
        "type": "function",
        "z": "tab_bridge",
        "name": "Load outbox message",
        "func": "const row = msg.replayRow || {};\ntry {\n  msg.topic = String(row.topic || '');\n  msg.payload = JSON.parse(String(row.payload || '{}'));\n  msg.replay = {\n    id: row.id,\n    messageId: row.message_id,\n    tries: Number(row.tries || 0)\n  };\n  return [msg, null];\n} catch (err) {\n  msg.replay = {\n    id: row.id,\n    messageId: row.message_id,\n    tries: Number(row.tries || 0)\n  };\n  msg.replayError = `Invalid outbox payload JSON: ${err.message}`;\n  return [null, msg];\n}\n",
